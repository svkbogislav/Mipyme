# Copia este archivo como ".env" (sin .example) en esta misma carpeta.
# La app Mac lee este archivo al iniciar. NUNCA lo subas a la nube.

# Subdominio de tu tienda Shopify (sin https:// ni .myshopify.com)
# Ej: si admin es https://drinkingpartners.myshopify.com → drinkingpartners
SHOPIFY_STORE=drinkingpartners

# Access token de tu Custom App de Shopify (empieza con shpat_)
# Generación: ver LEEME-MAC.md sección "Configurar Shopify"
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Versión de la API (puedes dejar el default)
SHOPIFY_API_VERSION=2024-10
