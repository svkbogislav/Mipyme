{
  "name": "mipyme",
  "version": "1.0.75",
  "description": "Mipyme — App de finanzas para PyMEs chilenas",
  "main": "main.js",
  "author": "Sebastián von Koeller",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist:mac": "electron-builder --mac --arm64 --x64",
    "dist:mac-arm": "electron-builder --mac --arm64",
    "dist:mac-intel": "electron-builder --mac --x64",
    "dist:win": "electron-builder --win --x64",
    "dist:all": "electron-builder -mwl",
    "release": "electron-builder --mac --arm64 --x64 --win --x64 --publish always",
    "release:mac": "electron-builder --mac --arm64 --x64 --publish always",
    "release:win": "electron-builder --win --x64 --publish always",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "cl.mipyme.app",
    "productName": "Mipyme",
    "copyright": "© 2026 Mipyme",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "svkbogislav",
      "repo": "Mipyme",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "Mipyme",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mipyme",
      "uninstallDisplayName": "Mipyme",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "xlsx": "^0.18.5"
  }
}
